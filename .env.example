# Copy this file to `.env` and fill in your own values.
#
#   cp .env.example .env
#
# `.env` is git-ignored, so your secrets stay local.

# Postgres connection string.
#
# Linux/macOS:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/linuxtutor"
#
# Windows + Postgres in WSL:
# DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/linuxtutor?sslmode=disable"

# Your Anthropic API key — get one at https://console.anthropic.com/.
# The lessons, hint/Q&A, and answer verification all call Claude.
ANTHROPIC_API_KEY="sk-ant-..."

# Optional — which Claude model to use (defaults to claude-sonnet-4-6).
# ANTHROPIC_MODEL="claude-sonnet-4-6"

# Optional — port for the dev server (defaults to 3000).
# PORT="3000"
